{
  "name": "atlas-explorer",
  "version": "1.0.1",
  "description": "A powerful file explorer built with Electron, w2ui, and Node.js",
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "debug:port": "electron . --remote-debugging-port=9222",
    "debug:cli": "node debug-electron.js",
    "build": "electron-builder",
    "test": "jest --watch",
    "test:coverage": "jest --coverage",
    "sync-assets": "node scripts/sync-assets.js",
    "db:reinit": "node scripts/reinitialize-db.js",
    "build:demo": "node demo/build.js",
    "build:server": "node server/build.js",
    "server": "node server/run.js",
    "postinstall": "electron-rebuild better-sqlite3 node-pty --build-from-source"
  },
  "build": {
    "appId": "com.mdkrieg.atlasexplorer",
    "productName": "Atlas Explorer",
    "directories": {
      "buildResources": "assets"
    },
    "extraResources": [
      {
        "from": "assets/icons",
        "to": "icons"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    },
    "fileAssociations": [
      {
        "ext": "aly",
        "name": "Atlas Layout",
        "role": "Editor"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "mdkrieg",
      "repo": "AtlasExplorer",
      "releaseType": "draft"
    },
    "files": [
      "**/*",
      "!demo/**"
    ]
  },
  "keywords": [
    "file",
    "explorer",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.0.0",
    "jest": "^29.7.0",
    "puppeteer": "^24.40.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^11.0.0",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "jquery": "^3.7.1",
    "markdown-it": "^14.1.1",
    "monaco-editor": "^0.47.0",
    "node-pty": "^1.1.0",
    "sharp": "^0.33.1",
    "w2ui": "^2.0.0"
  }
}
