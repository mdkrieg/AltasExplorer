{
  "name": "atlas-explorer",
  "version": "1.0.0",
  "description": "A powerful file explorer built with Electron, w2ui, and Node.js",
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "test": "jest --watch",
    "test:coverage": "jest --coverage",
    "postinstall": "electron-rebuild better-sqlite3 --build-from-source"
  },
  "build": {
    "appId": "com.mdkrieg.atlasexplorer",
    "productName": "Atlas Explorer",
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    }
  },
  "keywords": [
    "file",
    "explorer",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.0.0",
    "jest": "^29.7.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "jquery": "^3.7.1",
    "markdown-it": "^14.1.1",
    "monaco-editor": "^0.47.0",
    "sharp": "^0.33.1",
    "w2ui": "^2.0.0"
  }
}
